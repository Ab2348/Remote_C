[Unit]
Description=Remote C - Control remoto local
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/carlos/Documentos/Remote_C
ExecStart=/home/carlos/Documentos/Remote_C/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8765

Restart=on-failure
RestartSec=2

Environment=PYTHONUNBUFFERED=1
Environment=PYTHONDONTWRITEBYTECODE=1

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
UMask=0077

[Install]
WantedBy=default.target